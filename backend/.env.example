# ─── EDUPlan Backend — Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in your real values.
# Never commit .env to git.

# Django
DJANGO_SECRET_KEY=replace-with-a-long-random-string
DEBUG=True

# AI provider selection: azure | huggingface
AI_PROVIDER=azure

# Optional shared preferences/tuning
# AI_SYSTEM_PROMPT=You are Phoenix, an AI study assistant inside EDUPlan...
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=1024
AI_REQUEST_TIMEOUT_SECONDS=60

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE_NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=YOUR_AZURE_OPENAI_API_KEY
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Hugging Face (Llama 3.3 example)
HUGGINGFACE_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HUGGINGFACE_MODEL=meta-llama/Llama-3.3-70B-Instruct
# Optional override:
# HUGGINGFACE_API_URL=https://api-inference.huggingface.co/models/meta-llama/Llama-3.3-70B-Instruct
